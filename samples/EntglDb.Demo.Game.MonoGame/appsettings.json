{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft": "Warning",
      "System": "Warning",
      "EntglDb": "Warning"
    }
  },
  "EntglDb": {
    "Network": {
      "TcpPort": 5003,
      "UdpPort": 6003,
      "AuthToken": "DungeonCrawler-Secret",
      "ConnectionTimeoutMs": 5000,
      "RetryAttempts": 3,
      "RetryDelayMs": 1000,
      "LocalhostOnly": false
    },
    "Persistence": {
      "EnableWalMode": true,
      "CacheSizeMb": 50,
      "EnableAutoBackup": false,
      "BusyTimeoutMs": 5000
    },
    "Sync": {
      "SyncIntervalMs": 5000,
      "BatchSize": 100,
      "EnableOfflineQueue": true,
      "MaxQueueSize": 1000
    },
    "KnownPeers": []
  }
}
